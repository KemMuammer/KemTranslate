<Window x:Class="KemTranslate.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings" Height="560" Width="720" WindowStartupLocation="CenterOwner" ResizeMode="CanResizeWithGrip" MinWidth="620" MinHeight="420"
        Background="{DynamicResource WindowBackground}" Foreground="{DynamicResource ForegroundBrush}">
    <Window.Resources>
        <SolidColorBrush x:Key="SwitchOffBrush" Color="#FFD84C4C" />
        <SolidColorBrush x:Key="SwitchOnBrush" Color="#FF34C759" />

        <Style x:Key="ModifierCheckBoxStyle" TargetType="CheckBox">
            <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <StackPanel Orientation="Horizontal">
                            <Border x:Name="Box"
                                    Width="18"
                                    Height="18"
                                    CornerRadius="4"
                                    Background="{DynamicResource TextBoxBackground}"
                                    BorderBrush="{DynamicResource FloatingBorderBrush}"
                                    BorderThickness="1"
                                    VerticalAlignment="Center">
                                <Path x:Name="Check"
                                      Data="M 3 9 L 7 13 L 15 5"
                                      Stroke="White"
                                      StrokeThickness="2"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      StrokeLineJoin="Round"
                                      Visibility="Collapsed" />
                            </Border>
                            <ContentPresenter Margin="8,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Box" Property="Background" Value="{DynamicResource AccentBrush}" />
                                <Setter TargetName="Box" Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                                <Setter TargetName="Check" Property="Visibility" Value="Visible" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Box" Property="BorderBrush" Value="{DynamicResource ForegroundBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Box" Property="Opacity" Value="0.5" />
                                <Setter Property="Opacity" Value="0.7" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SwitchCheckBoxStyle" TargetType="CheckBox">
            <Setter Property="Focusable" Value="False" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="UseLayoutRounding" Value="True" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Canvas Width="52" Height="30" VerticalAlignment="Center" SnapsToDevicePixels="True">
                            <Border x:Name="SwitchTrack"
                                    Width="52"
                                    Height="30"
                                    CornerRadius="15"
                                    Background="{StaticResource SwitchOffBrush}"
                                    BorderBrush="#33FFFFFF"
                                    BorderThickness="1" />
                            <Border x:Name="SwitchThumb"
                                    Width="24"
                                    Height="24"
                                    Background="White"
                                    CornerRadius="12"
                                    Canvas.Left="3"
                                    Canvas.Top="3" />
                        </Canvas>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="SwitchTrack" Property="Background" Value="{StaticResource SwitchOnBrush}" />
                                <Setter TargetName="SwitchThumb" Property="Canvas.Left" Value="25" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="SwitchTrack" Property="Opacity" Value="0.5" />
                                <Setter TargetName="SwitchThumb" Property="Opacity" Value="0.7" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SettingTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}" />
        </Style>

        <Style x:Key="SettingDescriptionStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style x:Key="InlineApiKeyTextBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource TextBoxForeground}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="InlineApiKeyPasswordBoxStyle" TargetType="PasswordBox">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource TextBoxForeground}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="PasswordBox">
                        <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ApiKeyToggleButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontFamily" Value="Segoe UI Emoji" />
        </Style>

        <Style x:Key="HotkeyToggleButtonStyle" TargetType="ToggleButton">
            <Setter Property="Height" Value="34" />
            <Setter Property="MinWidth" Value="58" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Padding" Value="14,0" />
            <Setter Property="Background" Value="{DynamicResource ButtonBackground}" />
            <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource FloatingBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="ToggleBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ToggleBorder" Property="BorderBrush" Value="{DynamicResource ForegroundBrush}" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="ToggleBorder" Property="Background" Value="{DynamicResource AccentBrush}" />
                                <Setter Property="Foreground" Value="{DynamicResource AccentForegroundBrush}" />
                                <Setter TargetName="ToggleBorder" Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="HotkeyActionButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Height" Value="34" />
            <Setter Property="MinWidth" Value="42" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Padding" Value="12,0" />
        </Style>

        <Style x:Key="FieldPlaceholderStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
            <Setter Property="Margin" Value="10,0,10,0" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="IsHitTestVisible" Value="False" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>
    </Window.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,14">
            <TextBlock Text="Settings" FontSize="24" FontWeight="SemiBold" Foreground="{DynamicResource ForegroundBrush}" />
            <TextBlock Margin="0,4,0,0"
                       Text="Configure the global shortcut, appearance, and window behavior."
                       Foreground="{DynamicResource TextSecondaryBrush}" />
        </StackPanel>

        <Border Grid.Row="1"
                Margin="0,0,0,12"
                Padding="16"
                Background="{DynamicResource ControlBackground}"
                CornerRadius="12">
            <StackPanel>
                <TextBlock Text="Global hotkey" Style="{StaticResource SettingTitleStyle}" />
                <TextBlock Margin="0,4,0,14"
                           Text="Choose the required modifiers, key, and double-tap threshold."
                           Style="{StaticResource SettingDescriptionStyle}" />

                <StackPanel Margin="0,0,0,12">
                    <TextBlock Text="Required modifiers and key" Style="{StaticResource SettingTitleStyle}" />
                    <WrapPanel Margin="0,10,0,0">
                        <ToggleButton x:Name="TglCtrl" Content="Strg" Style="{StaticResource HotkeyToggleButtonStyle}" />
                        <ToggleButton x:Name="TglAlt" Content="Alt" Style="{StaticResource HotkeyToggleButtonStyle}" />
                        <ToggleButton x:Name="TglShift" Content="Umschalttaste" Style="{StaticResource HotkeyToggleButtonStyle}" />
                        <ToggleButton x:Name="TglWin" Content="Windows-Taste" Style="{StaticResource HotkeyToggleButtonStyle}" />
                        <ToggleButton x:Name="TglCaptureKey"
                                      MinWidth="72"
                                      Content="C"
                                      ToolTip="Activate and press a key"
                                      Checked="TglCaptureKey_Checked"
                                      Unchecked="TglCaptureKey_Unchecked"
                                      Style="{StaticResource HotkeyToggleButtonStyle}" />
                        <Button x:Name="BtnResetHotkey"
                                Content="↺"
                                FontFamily="Segoe UI Symbol"
                                ToolTip="Reset to Ctrl+C"
                                Click="BtnResetHotkey_Click"
                                Style="{StaticResource HotkeyActionButtonStyle}" />
                    </WrapPanel>
                </StackPanel>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Double-tap threshold (ms)" Style="{StaticResource SettingTitleStyle}" />
                        <TextBlock Margin="0,2,0,0" Text="How fast the hotkey must be pressed twice." Style="{StaticResource SettingDescriptionStyle}" />
                    </StackPanel>

                    <TextBox x:Name="TxtThreshold" Grid.Column="1" Width="110" Height="28" VerticalContentAlignment="Center" Padding="6,2" />
                </Grid>
            </StackPanel>
        </Border>

        <Border Grid.Row="2"
                Margin="0,0,0,12"
                Padding="16"
                Background="{DynamicResource ControlBackground}"
                CornerRadius="12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="0,0,16,0">
                        <TextBlock Text="Use dark theme" Style="{StaticResource SettingTitleStyle}" />
                        <TextBlock Text="Switch the application between light and dark appearance." Style="{StaticResource SettingDescriptionStyle}" />
                    </StackPanel>
                    <CheckBox x:Name="ChkDark" Grid.Column="1" Style="{StaticResource SwitchCheckBoxStyle}" />
                </Grid>

                <Grid Grid.Row="1" Margin="0,0,0,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="0,0,16,0">
                        <TextBlock Text="Close button minimizes to tray" Style="{StaticResource SettingTitleStyle}" />
                        <TextBlock Text="Keep the app running in the notification area when closing the main window." Style="{StaticResource SettingDescriptionStyle}" />
                    </StackPanel>
                    <CheckBox x:Name="ChkMinimizeToTray" Grid.Column="1" Style="{StaticResource SwitchCheckBoxStyle}" />
                </Grid>

                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="0,0,16,0">
                        <TextBlock Text="Global hotkey opens main window" Style="{StaticResource SettingTitleStyle}" />
                        <TextBlock Text="When enabled, hotkey translations open in the main window instead of the floating translator." Style="{StaticResource SettingDescriptionStyle}" />
                    </StackPanel>
                    <CheckBox x:Name="ChkHotkeyOpensMain" Grid.Column="1" Style="{StaticResource SwitchCheckBoxStyle}" />
                </Grid>
            </Grid>
        </Border>

        <Border Grid.Row="3"
                Margin="0,0,0,12"
                Padding="16"
                Background="{DynamicResource ControlBackground}"
                CornerRadius="12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="0,0,16,0">
                        <TextBlock Text="Start minimized to tray" Style="{StaticResource SettingTitleStyle}" />
                        <TextBlock Text="Launch the app hidden in the notification area." Style="{StaticResource SettingDescriptionStyle}" />
                    </StackPanel>
                    <CheckBox x:Name="ChkStartMinimized" Grid.Column="1" Style="{StaticResource SwitchCheckBoxStyle}" />
                </Grid>

                <Grid Grid.Row="1" Margin="0,0,0,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="0,0,16,0">
                        <TextBlock Text="Start with Windows" Style="{StaticResource SettingTitleStyle}" />
                        <TextBlock Text="Launch KemTranslate automatically after you sign in." Style="{StaticResource SettingDescriptionStyle}" />
                    </StackPanel>
                    <CheckBox x:Name="ChkStartWithWindows" Grid.Column="1" Style="{StaticResource SwitchCheckBoxStyle}" />
                </Grid>

                <Grid Grid.Row="2" Margin="0,0,0,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="220" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="120" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,16,0">
                        <TextBlock Text="Editor font" Style="{StaticResource SettingTitleStyle}" />
                        <TextBlock Text="Used for translation and write input/output controls." Style="{StaticResource SettingDescriptionStyle}" />
                    </StackPanel>

                    <ComboBox x:Name="CmbEditorFontFamily"
                              Grid.Column="1"
                              Height="28"
                              VerticalContentAlignment="Center"
                              Padding="6,2"
                              IsTextSearchEnabled="True"
                              ToolTip="Installed editor fonts" />

                    <TextBox x:Name="TxtEditorFontSize"
                             Grid.Column="3"
                             Height="28"
                             VerticalContentAlignment="Center"
                             Padding="6,2"
                             ToolTip="Example: 20" />
                </Grid>

                <Grid Grid.Row="3" Margin="0,0,0,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="220" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,16,0">
                        <TextBlock Text="Current hotkey" Style="{StaticResource SettingTitleStyle}" />
                        <TextBlock Text="Updates while you toggle modifiers or capture a key." Style="{StaticResource SettingDescriptionStyle}" />
                    </StackPanel>

                    <TextBlock x:Name="TxtHotkeyPreview"
                               Grid.Column="1"
                               VerticalAlignment="Center"
                               FontSize="14"
                               FontWeight="SemiBold" />
                </Grid>

                <Grid Grid.Row="4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="220" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,16,0">
                        <TextBlock Text="Logging level" Style="{StaticResource SettingTitleStyle}" />
                        <TextBlock Text="Log files are written to the logs folder next to the application." Style="{StaticResource SettingDescriptionStyle}" />
                    </StackPanel>

                    <ComboBox x:Name="CmbLogLevel"
                              Grid.Column="1"
                              Height="28"
                              Width="160"
                              HorizontalAlignment="Left"
                              VerticalContentAlignment="Center"
                              Padding="6,2" />
                </Grid>

                <Grid Grid.Row="5" Margin="0,14,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="220" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,16,0">
                        <TextBlock Text="OCR executable path" Style="{StaticResource SettingTitleStyle}" />
                        <TextBlock Text="Optional path to tesseract.exe. Leave empty to auto-detect." Style="{StaticResource SettingDescriptionStyle}" />
                    </StackPanel>

                    <TextBox x:Name="TxtOcrExecutablePath"
                             Grid.Column="1"
                             Height="28"
                             VerticalContentAlignment="Center"
                             Padding="6,2"
                             ToolTip="Example: C:\Program Files\Tesseract-OCR\tesseract.exe" />

                    <Button x:Name="BtnOpenOcrFolder"
                            Grid.Column="2"
                            Width="110"
                            Height="28"
                            Margin="8,0,0,0"
                            Content="Open folder"
                            Click="BtnOpenOcrFolder_Click" />
                </Grid>

                <Grid Grid.Row="6" Margin="0,14,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="220" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,16,0">
                        <TextBlock Text="OCR language" Style="{StaticResource SettingTitleStyle}" />
                        <TextBlock Text="Tesseract language code such as eng, deu, or eng+deu." Style="{StaticResource SettingDescriptionStyle}" />
                    </StackPanel>

                    <TextBox x:Name="TxtOcrLanguage"
                             Grid.Column="1"
                             Height="28"
                             Width="160"
                             HorizontalAlignment="Left"
                             VerticalContentAlignment="Center"
                             Padding="6,2"
                             ToolTip="Example: eng" />
                </Grid>

                <Grid Grid.Row="7" Margin="0,14,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="220" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,16,0">
                        <TextBlock Text="OCR shortcut" Style="{StaticResource SettingTitleStyle}" />
                        <TextBlock Text="Shortcut for starting OCR capture inside the app." Style="{StaticResource SettingDescriptionStyle}" />
                    </StackPanel>

                    <StackPanel Grid.Column="1">
                        <WrapPanel Margin="0,0,0,8">
                            <ToggleButton x:Name="TglOcrCtrl" Content="Ctrl" Style="{StaticResource HotkeyToggleButtonStyle}" />
                            <ToggleButton x:Name="TglOcrAlt" Content="Alt" Style="{StaticResource HotkeyToggleButtonStyle}" />
                            <ToggleButton x:Name="TglOcrShift" Content="Shift" Style="{StaticResource HotkeyToggleButtonStyle}" />
                            <ToggleButton x:Name="TglOcrWin" Content="Win" Style="{StaticResource HotkeyToggleButtonStyle}" />
                            <ToggleButton x:Name="TglOcrCaptureKey"
                                          MinWidth="72"
                                          Content="O"
                                          ToolTip="Activate and press a key"
                                          Checked="TglOcrCaptureKey_Checked"
                                          Unchecked="TglOcrCaptureKey_Unchecked"
                                          Style="{StaticResource HotkeyToggleButtonStyle}" />
                            <Button x:Name="BtnResetOcrShortcut"
                                    Content="↺"
                                    FontFamily="Segoe UI Symbol"
                                    ToolTip="Reset to Ctrl+Shift+O"
                                    Click="BtnResetOcrShortcut_Click"
                                    Style="{StaticResource HotkeyActionButtonStyle}" />
                        </WrapPanel>

                        <TextBlock x:Name="TxtOcrShortcutPreview"
                                   VerticalAlignment="Center"
                                   FontSize="14"
                                   FontWeight="SemiBold" />
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>

        <Border Grid.Row="4"
                Margin="0,0,0,12"
                Padding="16"
                Background="{DynamicResource ControlBackground}"
                CornerRadius="12">
            <StackPanel>
                <TextBlock Text="LibreTranslate" Style="{StaticResource SettingTitleStyle}" />
                <TextBlock Margin="0,4,0,14"
                           Text="Configure the LibreTranslate server endpoint and API key used for language loading and translation requests."
                           Style="{StaticResource SettingDescriptionStyle}" />

                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="220" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,16,0">
                        <TextBlock Text="Server URL" Style="{StaticResource SettingTitleStyle}" />
                        <TextBlock Text="Example: https://your-server.example/" Style="{StaticResource SettingDescriptionStyle}" />
                    </StackPanel>

                    <Grid Grid.Column="1">
                        <TextBox x:Name="TxtServerUrl"
                                 Height="28"
                                 VerticalContentAlignment="Center"
                                 Padding="6,2"
                                 TextChanged="ConnectionField_TextChanged"
                                 ToolTip="LibreTranslate base URL" />
                        <TextBlock x:Name="TxtServerUrlPlaceholder"
                                   Text="https://your-server.example/translate"
                                   Style="{StaticResource FieldPlaceholderStyle}" />
                    </Grid>
                </Grid>

                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="220" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,16,0">
                        <TextBlock Text="API key" Style="{StaticResource SettingTitleStyle}" />
                        <TextBlock Text="Leave empty if your LibreTranslate server does not require a key." Style="{StaticResource SettingDescriptionStyle}" />
                    </StackPanel>

                    <Grid Grid.Column="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0"
                                Background="{DynamicResource TextBoxBackground}"
                                BorderBrush="{DynamicResource ControlBackground}"
                                BorderThickness="1"
                                CornerRadius="4">
                            <Grid>
                                <PasswordBox x:Name="TxtApiKeyPassword"
                                             Style="{StaticResource InlineApiKeyPasswordBoxStyle}"
                                             PasswordChanged="TxtApiKeyPassword_PasswordChanged"
                                             ToolTip="LibreTranslate API key" />
                                <TextBox x:Name="TxtApiKey"
                                         Style="{StaticResource InlineApiKeyTextBoxStyle}"
                                         FontFamily="Consolas"
                                         Visibility="Collapsed"
                                         TextChanged="TxtApiKey_TextChanged"
                                         ToolTip="LibreTranslate API key" />
                                <TextBlock x:Name="TxtApiKeyPlaceholder"
                                           Text="example-api-key"
                                           Style="{StaticResource FieldPlaceholderStyle}" />
                            </Grid>
                        </Border>

                        <Button x:Name="BtnToggleApiKeyVisibility"
                                Grid.Column="1"
                                Width="36"
                                Height="28"
                                Margin="8,0,0,0"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Center"
                                Style="{StaticResource ApiKeyToggleButtonStyle}"
                                Content="👁"
                                ToolTip="Show or hide API key"
                                Click="BtnToggleApiKeyVisibility_Click" />
                    </Grid>
                </Grid>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="220" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,16,0">
                        <TextBlock Text="LanguageTool Server URL" Style="{StaticResource SettingTitleStyle}" />
                        <TextBlock Text="Example: https://your-languagetool-server.example/v2/" Style="{StaticResource SettingDescriptionStyle}" />
                    </StackPanel>

                    <Grid Grid.Column="1">
                        <TextBox x:Name="TxtLanguageToolServerUrl"
                                 Height="28"
                                 VerticalContentAlignment="Center"
                                 Padding="6,2"
                                 TextChanged="ConnectionField_TextChanged"
                                 ToolTip="LanguageTool base URL" />
                        <TextBlock x:Name="TxtLanguageToolServerUrlPlaceholder"
                                   Text="https://your-languagetool-server.example/v2/"
                                   Style="{StaticResource FieldPlaceholderStyle}" />
                    </Grid>
                </Grid>
            </StackPanel>
        </Border>

        <TextBlock Grid.Row="5"
                   Text="Tip: enter a single key such as C. The switch is red when off and green when on."
                   Style="{StaticResource SettingDescriptionStyle}" />

        <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button x:Name="BtnOK" Width="92" Height="32" Margin="6,0,0,0" Click="BtnOK_Click">OK</Button>
            <Button Width="92" Height="32" Margin="6,0,0,0" Click="BtnCancel_Click">Cancel</Button>
        </StackPanel>
    </Grid>
    </ScrollViewer>
</Window>
