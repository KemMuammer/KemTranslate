<Window x:Class="KemTranslate.FloatingTranslateWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Quick Translator"
        Width="480"
        Height="300"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True">
    <Window.Resources>
        <Style x:Key="FloatingIconButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="32" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontFamily" Value="Segoe UI Symbol" />
            <Setter Property="FontWeight" Value="Normal" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>

        <Style x:Key="CollapsedCircleButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="42" />
            <Setter Property="Height" Value="42" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="FontFamily" Value="Segoe UI Symbol" />
            <Setter Property="FontWeight" Value="Normal" />
            <Setter Property="FontSize" Value="26" />
            <Setter Property="Background" Value="{DynamicResource ButtonBackground}" />
            <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource FloatingBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12"
                                SnapsToDevicePixels="True"
                                ClipToBounds="True">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Border x:Name="CollapsedRoot"
                Width="50"
                Height="50"
                CornerRadius="16"
                Background="{DynamicResource FloatingPanelBackground}"
                BorderBrush="{DynamicResource FloatingBorderBrush}"
                BorderThickness="1"
                MouseEnter="CollapsedRoot_MouseEnter"
                MouseLeave="CollapsedRoot_MouseLeave"
                PreviewMouseLeftButtonDown="DragSurface_PreviewMouseLeftButtonDown">
            <Grid ClipToBounds="True">
                <Button Margin="4,4,0,4"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        Style="{StaticResource CollapsedCircleButtonStyle}"
                        Background="{DynamicResource AccentBrush}"
                        BorderBrush="{DynamicResource AccentBrush}"
                        Foreground="{DynamicResource AccentForegroundBrush}"
                        Click="BtnCollapsedOpen_Click">
                    <Grid Width="34" Height="34" ClipToBounds="True">
                        <Image Source="pack://application:,,,/Assets/kemtranslate.png"
                               Stretch="Uniform"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Width="34"
                               Height="34"
                               RenderTransformOrigin="0.5,0.5">
                            <Image.RenderTransform>
                                <TranslateTransform X="1.5" />
                            </Image.RenderTransform>
                        </Image>
                    </Grid>
                </Button>

                <Button x:Name="BtnCollapsedHide"
                        Margin="51,4,0,4"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        Style="{StaticResource CollapsedCircleButtonStyle}"
                        Opacity="0"
                        IsHitTestVisible="False"
                        Foreground="{DynamicResource ForegroundBrush}"
                        Click="BtnCollapsedHide_Click">
                    <Button.RenderTransform>
                        <TranslateTransform X="-18" />
                    </Button.RenderTransform>
                    <TextBlock Text="✕"
                               FontFamily="Segoe UI Symbol"
                               FontSize="28"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Margin="0,-3,0,0"
                               TextAlignment="Center" />
                </Button>
            </Grid>
        </Border>

        <Border x:Name="ExpandedRoot"
                Visibility="Collapsed"
                CornerRadius="16"
                Background="{DynamicResource FloatingWindowBackground}"
                BorderBrush="{DynamicResource FloatingBorderBrush}"
                BorderThickness="1"
                PreviewMouseLeftButtonDown="DragSurface_PreviewMouseLeftButtonDown">
            <Grid Margin="12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Button x:Name="BtnModeTranslate"
                            Grid.Column="0"
                            Width="104"
                            Height="34"
                            Margin="0,0,8,0"
                            Content="Translate"
                            Click="BtnTranslateSelection_Click" />

                    <Button x:Name="BtnModeWrite"
                            Grid.Column="1"
                            Width="84"
                            Height="34"
                            Margin="0,0,10,0"
                            Content="Write"
                            Click="BtnWriteSelection_Click" />

                    <ComboBox x:Name="CmbTarget"
                              Grid.Column="2"
                              Height="34"
                              Margin="0,0,10,0"
                              DisplayMemberPath="display"
                              SelectionChanged="CmbTarget_SelectionChanged" />

                    <TextBlock x:Name="TxtWriteModeInfo"
                               Grid.Column="2"
                               Margin="0,0,10,0"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               Text="Fix text with LanguageTool"
                               Visibility="Collapsed" />

                    <Button Grid.Column="3"
                            Margin="0,0,6,0"
                            Content="⛶"
                            Style="{StaticResource FloatingIconButtonStyle}"
                            Foreground="{DynamicResource ForegroundBrush}"
                            ToolTip="Capture screen text (OCR)"
                            Click="BtnOcrCapture_Click" />
                    <Button Grid.Column="4"
                            Margin="0,0,6,0"
                            Content="⚙"
                            Style="{StaticResource FloatingIconButtonStyle}"
                            Foreground="{DynamicResource ForegroundBrush}"
                            Click="BtnSettings_Click" />
                    <Button Grid.Column="5"
                            Content="✕"
                            Style="{StaticResource FloatingIconButtonStyle}"
                            Foreground="{DynamicResource ForegroundBrush}"
                            Click="BtnCollapse_Click" />
                </Grid>

                <TextBlock x:Name="TxtSourceInfo"
                           Grid.Row="1"
                           Margin="2,0,2,8"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           TextWrapping="Wrap" />

                <RichTextBox x:Name="TxtTranslation"
                             Grid.Row="2"
                             IsReadOnly="True"
                             IsDocumentEnabled="False"
                             VerticalScrollBarVisibility="Auto"
                             FontSize="14"
                             FontFamily="Consolas"
                             Background="{DynamicResource TextBoxBackground}"
                             Foreground="{DynamicResource TextBoxForeground}"
                             BorderBrush="{DynamicResource ControlBackground}"
                             BorderThickness="1"
                             Padding="8" />

                <Grid Grid.Row="3" Margin="0,10,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0"
                            Width="96"
                            Height="34"
                            Margin="0,0,8,0"
                            Content="Copy"
                            Click="BtnCopy_Click" />
                    <Button Grid.Column="1"
                            Width="126"
                            Height="34"
                            Content="Open in app"
                            Click="BtnOpenMain_Click" />
                    <Button Grid.Column="3"
                            Width="108"
                            Height="34"
                            Background="{DynamicResource AccentBrush}"
                            Foreground="{DynamicResource AccentForegroundBrush}"
                            Content="Replace"
                            Click="BtnReplace_Click" />
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
