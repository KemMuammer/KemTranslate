<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <SolidColorBrush x:Key="WindowBackground" Color="#FF111111" />
    <SolidColorBrush x:Key="ForegroundBrush" Color="#FFF0F0F0" />
    <SolidColorBrush x:Key="ControlBackground" Color="#FF1E1E1E" />
    <SolidColorBrush x:Key="TextBoxBackground" Color="#FF1B1B1B" />
    <SolidColorBrush x:Key="TextBoxForeground" Color="#FFF0F0F0" />
    <SolidColorBrush x:Key="ButtonBackground" Color="#FF2A2A2A" />
    <SolidColorBrush x:Key="ButtonForeground" Color="#FFF0F0F0" />
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="#FFB0B0B0" />
    <SolidColorBrush x:Key="AccentBrush" Color="#FF0A6CFF" />
    <SolidColorBrush x:Key="AccentForegroundBrush" Color="White" />
    <SolidColorBrush x:Key="FloatingWindowBackground" Color="#FF242424" />
    <SolidColorBrush x:Key="FloatingPanelBackground" Color="#FF2E2E2E" />
    <SolidColorBrush x:Key="FloatingBorderBrush" Color="#FF3C3C3C" />
</ResourceDictionary>