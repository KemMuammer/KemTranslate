<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <SolidColorBrush x:Key="WindowBackground" Color="White" />
    <SolidColorBrush x:Key="ForegroundBrush" Color="Black" />
    <SolidColorBrush x:Key="ControlBackground" Color="#FFF5F5F5" />
    <SolidColorBrush x:Key="TextBoxBackground" Color="White" />
    <SolidColorBrush x:Key="TextBoxForeground" Color="Black" />
    <SolidColorBrush x:Key="ButtonBackground" Color="#FFECECEC" />
    <SolidColorBrush x:Key="ButtonForeground" Color="Black" />
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="#FF6F6F6F" />
    <SolidColorBrush x:Key="AccentBrush" Color="#FF0F6CBD" />
    <SolidColorBrush x:Key="AccentForegroundBrush" Color="Black" />
    <SolidColorBrush x:Key="FloatingWindowBackground" Color="#FFF7F7F8" />
    <SolidColorBrush x:Key="FloatingPanelBackground" Color="#FFF1F1F1" />
    <SolidColorBrush x:Key="FloatingBorderBrush" Color="#FFD8D8D8" />
</ResourceDictionary>